# LLM Provider configuration
# Can be 'anthropic', 'openai', or 'openrouter'
LLM_PROVIDER=anthropic
LLM_MODEL=
PLANNER_MODEL=
CODER_MODEL=
TESTER_MODEL=
REVIEWER_MODEL=

# API Keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=openai/gpt-4.1-mini
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_APP_NAME=ai-code-agent
OPENROUTER_SITE_URL=

# Version Control Integrations
GITHUB_TOKEN=your_github_personal_access_token
AZURE_DEVOPS_PAT=your_azure_devops_personal_access_token
AZURE_DEVOPS_ORG_URL=https://dev.azure.com/yourorg

# Sandbox Configuration
# Set to 'docker' or 'local' (local is unsafe, use for debugging only)
SANDBOX_MODE=docker
DOCKER_IMAGE_NAME=ai-code-agent-sandbox:latest

# Runtime Behavior
AGENT_WORKSPACE_DIR=.
AGENT_SKILLS_ENABLED=true
AGENT_SKILL_PATHS=d:\work\agent\skills
AGENT_SKILL_ALLOWED_PERMISSIONS=read-only
AUTO_COMMIT=false
AUTO_PUSH=false
